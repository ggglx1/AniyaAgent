LLM_PROVIDER=anthropic

# Required by the private Web product. Use a long random value and never commit it.
ANIYAAGENT_OWNER_TOKEN=replace_with_a_long_random_owner_token

# structured_only is the normal runtime. legacy_audit only reports old Markdown
# memory; legacy_migration only enables its preview/backup/confirmed import tools.
MEMORY_MODE=structured_only
# Semantic extraction is optional and disabled by default. Its output is only a candidate.
MEMORY_EXTRACTION_LLM_ENABLED=false

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL_ID=claude-3-5-sonnet-latest

# Optional. Leave empty or remove this line when using the official Anthropic API.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI or an OpenAI-compatible service. OPENAI_BASE_URL may end in /v1
# or contain the complete /v1/chat/completions endpoint.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_ID=gpt-4.1
